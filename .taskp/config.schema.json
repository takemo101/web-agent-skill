{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"type": "object",
	"properties": {
		"ai": {
			"description": "AI/LLM settings",
			"type": "object",
			"properties": {
				"default_provider": {
					"description": "Default provider (anthropic | openai | google | ollama | omlx | lmstudio)",
					"type": "string",
					"minLength": 1
				},
				"default_model": {
					"description": "Default model name",
					"type": "string",
					"minLength": 1
				},
				"providers": {
					"description": "Per-provider settings",
					"type": "object",
					"propertyNames": {
						"type": "string"
					},
					"additionalProperties": {
						"type": "object",
						"properties": {
							"api_key_env": {
								"description": "Environment variable name for API key",
								"type": "string",
								"minLength": 1
							},
							"base_url": {
								"description": "Custom endpoint URL",
								"type": "string",
								"minLength": 1
							},
							"default_model": {
								"description": "Default model for this provider",
								"type": "string",
								"minLength": 1
							},
							"api_type": {
								"description": "API type for custom OpenAI-compatible providers: 'chat' (Chat Completions API, default) or 'responses' (Responses API)",
								"type": "string",
								"enum": ["chat", "responses"]
							}
						},
						"additionalProperties": false
					}
				}
			},
			"additionalProperties": false
		},
		"hooks": {
			"description": "Lifecycle hooks",
			"type": "object",
			"properties": {
				"on_success": {
					"description": "Commands to run on skill success",
					"type": "array",
					"items": {
						"type": "string",
						"minLength": 1
					}
				},
				"on_failure": {
					"description": "Commands to run on skill failure",
					"type": "array",
					"items": {
						"type": "string",
						"minLength": 1
					}
				}
			},
			"additionalProperties": false
		},
		"cli": {
			"description": "CLI behavior settings",
			"type": "object",
			"properties": {
				"command_timeout_ms": {
					"description": "Default timeout for command execution in milliseconds",
					"type": "integer",
					"exclusiveMinimum": 0,
					"maximum": 9007199254740991
				},
				"max_agent_steps": {
					"description": "Maximum number of agent loop steps (1–200, default: 50)",
					"type": "integer",
					"minimum": 1,
					"maximum": 200
				}
			},
			"additionalProperties": false
		}
	},
	"additionalProperties": false
}
